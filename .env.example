# ─────────────────────────────────────────────────────────────────────
#  Aitch — environment template.  COPY to .env and fill locally.
#  .env is gitignored. NEVER commit real keys, secrets, or seed phrases.
#  Placeholder values only below — do not paste real material into this file.
# ─────────────────────────────────────────────────────────────────────

# ── GOAT network (mainnet) ──────────────────────────────────────────
# Chain 2345, USDC.e. These are safe, public, non-secret values.
GOAT_RPC_URL=https://rpc.goat.network
GOAT_CHAIN_ID=2345
USDC_E_CONTRACT=0x3022b87ac063DE95b1570F46f5e470F8B53112D8

# ── x402 order API (GoatX402Client) ─────────────────────────────────
# Class is GoatX402Client, param is baseUrl. Auth is HMAC done inside the SDK.
GOATX402_API_URL=https://x402-api.goat.network
GOATX402_MERCHANT_ID=your_merchant_id_here
GOATX402_API_KEY=your_api_key_here
GOATX402_API_SECRET=your_api_secret_here

# ── Two-wallet model (payer ≠ merchant, intentional) ────────────────
# A = merchant / Aitch (receives).  B = student / payer (pays).
# Public 0x… addresses are fine to share; the *_PRIVATE_KEY values are NOT.

# Merchant / Aitch wallet (A) — receives USDC.e
AGENT_ADDRESS=0xYourMerchantAddressHere
WALLET_PRIVATE_KEY=0xREPLACE_WITH_MERCHANT_PRIVATE_KEY_NEVER_COMMIT

# Student / payer wallet (B) — sends USDC.e
STUDENT_ADDRESS=0xYourStudentAddressHere
STUDENT_PRIVATE_KEY=0xREPLACE_WITH_STUDENT_PRIVATE_KEY_NEVER_COMMIT
